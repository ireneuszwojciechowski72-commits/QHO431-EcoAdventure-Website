<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>FAQ | Eco Adventure Wildlife Park</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <%- include("partials/header") %>

    <main>
      <section class="page-hero">
        <h1>Frequently Asked Questions</h1>
        <p>Helpful information for planning your visit.</p>
      </section>

      <section class="faq-section">
        <div class="faq-item">
          <button class="faq-question">What are your opening times?</button>
          <div class="faq-answer">
            <p>
              Eco Adventure Wildlife Park is open every day from 9:00 AM to 6:00
              PM.
            </p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">Are school visits available?</button>
          <div class="faq-answer">
            <p>
              Yes. Educational visits and group bookings can be arranged
              throughout the year.
            </p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">Can I buy tickets on arrival?</button>
          <div class="faq-answer">
            <p>
              Yes. Visitors can purchase tickets at the entrance subject to
              availability.
            </p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">
            Is the park wheelchair accessible?
          </button>
          <div class="faq-answer">
            <p>
              Most areas of the park are accessible and designed for visitors
              with mobility needs.
            </p>
          </div>
        </div>

        <div class="faq-item">
          <button class="faq-question">Are food and drinks available?</button>
          <div class="faq-answer">
            <p>
              Yes. Food, drinks and refreshments are available throughout the
              park.
            </p>
          </div>
        </div>
      </section>
    </main>
    <%- include("partials/footer") %>

    <script src="/js/faq.js"></script>
  </body>
</html>
