<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Habitats | Eco Adventure Wildlife Park</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <%- include("partials/header") %>

    <main>
      <section class="page-hero">
        <h1>Wildlife Habitats</h1>
        <p>Explore the themed habitats across Eco Adventure Wildlife Park.</p>
        <div class="opening-times-card">
          <h3>🌿 Opening Times</h3>
          <p>Open Daily: 9:00 AM – 6:00 PM</p>
        </div>
      </section>

      <section class="habitats-preview">
        <h2>Our Main Habitats</h2>

        <div class="cards-container">
          <div class="habitat-card">
            <h3>Tropical Rainforest</h3>
            <p>
              A warm, plant-rich habitat with dense vegetation, colourful birds,
              insects and small mammals.
            </p>
          </div>

          <div class="habitat-card">
            <h3>Savannah Plains</h3>
            <p>
              An open grassland habitat featuring large mammals, viewing areas
              and family-friendly learning points.
            </p>
          </div>

          <div class="habitat-card">
            <h3>Wetlands & River Trail</h3>
            <p>
              A calm water-based habitat with reeds, amphibians, water birds and
              freshwater conservation displays.
            </p>
          </div>

          <div class="habitat-card">
            <h3>Desert & Reptile House</h3>
            <p>
              A dry-climate habitat focused on reptiles, desert plants and
              adaptation to extreme environments.
            </p>
          </div>

          <div class="habitat-card">
            <h3>Ocean Discovery</h3>
            <p>
              An aquatic learning zone exploring marine life, coastal ecosystems
              and the importance of ocean protection.
            </p>
          </div>

          <div class="habitat-card">
            <h3>Arctic Expedition</h3>
            <p>
              A cold-climate habitat exploring polar wildlife, icy landscapes
              and climate conservation learning.
            </p>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
