<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Experiences | Eco Adventure Wildlife Park</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <%- include("partials/header") %>

    <main>
      <section class="page-hero">
        <h1>Wildlife Experiences</h1>
        <p>
          Discover exciting activities and educational experiences throughout
          the park.
        </p>
      </section>

      <section class="habitats-preview">
        <h2>Featured Experiences</h2>

        <div class="cards-container">
          <div class="habitat-card">
            <h3>🌿 Rainforest Canopy Walk</h3>
            <p>
              Explore elevated walkways through the rainforest habitat and learn
              about tropical ecosystems.
            </p>
          </div>

          <div class="habitat-card">
            <h3>🦁 Savannah Feeding Talk</h3>
            <p>
              Meet our wildlife team and discover how animals are cared for in
              the savannah zone.
            </p>
          </div>

          <div class="habitat-card">
            <h3>🦆 River Conservation Trail</h3>
            <p>
              Follow an educational trail focused on wetlands, freshwater
              habitats and conservation.
            </p>
          </div>

          <div class="habitat-card">
            <h3>🐍 Reptile Handling Talk</h3>
            <p>
              Learn about reptiles and adaptation through interactive keeper
              presentations.
            </p>
          </div>

          <div class="habitat-card">
            <h3>🌊 Ocean Discovery Lab</h3>
            <p>
              Take part in hands-on activities exploring marine life and ocean
              protection.
            </p>
          </div>

          <div class="habitat-card">
            <h3>❄️ Arctic Climate Station</h3>
            <p>
              Discover how polar wildlife survives in extreme environments and
              changing climates.
            </p>
          </div>
        </div>
      </section>
    </main>
    <%- include("partials/footer") %>
  </body>
</html>
