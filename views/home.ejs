<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Eco Adventure Wildlife Park</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <%- include('partials/header') %>
    <main>
      <section class="hero">
        <div class="hero-content">
          <p class="eyebrow">Open every day from 9am to 6pm</p>
          <h1>Explore Wildlife, Nature and Adventure</h1>
          <p>
            Discover immersive habitats, animal exhibits and outdoor experiences
            designed for families, schools and nature explorers.
          </p>
          <a href="/habitats" class="hero-button">Explore Habitats</a>
        </div>
      </section>

      <section class="opening-times">
        <h2>Opening Times</h2>
        <p class="opening-main">Open every day from 9am to 6pm</p>
        <p class="opening-note">
          Plan your visit and enjoy a full day of wildlife habitats, educational
          exhibits and outdoor adventure.
        </p>
      </section>
    </main>
    <%- include("partials/footer") %>
  </body>
</html>
