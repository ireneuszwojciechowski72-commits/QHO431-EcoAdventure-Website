<!DOCTYPE html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>Eco Adventure Wildlife Park</title>
    <link rel="stylesheet" href="/css/style.css" />
  </head>
  <body>
    <%- include('../partials/header') %>
    <main>
      <section class="hero">
        <div class="hero-content">
          <p class="eyebrow">Open every day from 9am to 6pm</p>
          <h1>Explore Wildlife, Nature and Adventure</h1>
          <p>
            Discover immersive habitats, animal exhibits and outdoor experiences
            designed for families, schools and nature explorers.
          </p>
          <a href="/habitats" class="hero-button">Explore Habitats</a>
        </div>
      </section>

      <section class="habitats-preview">
        <h2>Featured Habitats</h2>

        <div class="cards-container">
          <div class="habitat-card">
            <h3>Rainforest Zone</h3>
            <p>Discover tropical wildlife and exotic rainforest species.</p>
          </div>

          <div class="habitat-card">
            <h3>Arctic Expedition</h3>
            <p>Explore icy landscapes and arctic animal habitats.</p>
          </div>

          <div class="habitat-card">
            <h3>Safari Adventure</h3>
            <p>Experience the atmosphere of African wildlife and safaris.</p>
          </div>
        </div>
      </section>
    </main>
  </body>
</html>
